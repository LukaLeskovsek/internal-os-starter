# =============================================================================
# Environment variables — the contract for this app.
#
# Keys live here (locally, in .env.local) and in your Vercel project settings —
# never in code, never in chat, never in the knowledge base.
#
# Setup: copy this file to ".env.local" and fill it in. Same shape as the Day-2
# SaaS app, plus the Intrix variables at the bottom.
# =============================================================================

# --- Supabase: sign-in + database ---
NEXT_PUBLIC_SUPABASE_URL=           # Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # anon / publishable key — safe in the browser; RLS is the protection

# Lets Claude Code apply your database migrations for you (no pasting SQL into the dashboard).
# Create at supabase.com → Account → Access Tokens. Account-scoped — it's your own account; revoke after the program.
SUPABASE_ACCESS_TOKEN=

# Powers the Admin module's user management (add/role/disable/delete users).
# Supabase → Project Settings → API Keys → the **secret** key (`sb_secret_…`;
# the service_role replacement in the new key system). SERVER-ONLY and powerful:
# it BYPASSES Row Level Security. Never prefix with NEXT_PUBLIC, never put in code,
# never commit. Used only by lib/supabase/admin.ts behind owner checks.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend: transactional email ---
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev    # workshop default test sender; own domain after the program

# --- Sentry: error tracking ---
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# --- Intrix: the Day-3 reference integration (crm_demo module) ---
# This is the ONE shared credential in the whole program — Luka provides the key.
# Leave INTRIX_API_KEY empty to run the module in MOCK MODE (bundled demo data).
INTRIX_BASE_URL=                    # e.g. https://api.intrix.si/v1
INTRIX_API_KEY=

# --- AI: the system's LLM calls (lib/ai.ts, the ai_assist module) ---
# The SAME OpenRouter key your Hermes agent uses (openrouter.ai → Keys), capped.
# SERVER-ONLY: never prefix with NEXT_PUBLIC, never put it in code. Leave blank to
# run in mock mode (canned output, zero spend) — the module still works.
OPENROUTER_API_KEY=
# Default model is Claude via OpenRouter. Verify the current slug at
# openrouter.ai/models. Switch to an OpenAI model id here to swap providers.
OPENROUTER_MODEL=anthropic/claude-3.5-haiku
# The invoice_ocr module reads images + PDFs, so it needs a VISION + PDF capable model.
# Verify the current slug at openrouter.ai/models. Blank → the module's mock sample
# invoice (zero spend), like the other AI features.
OPENROUTER_VISION_MODEL=anthropic/claude-3.5-sonnet

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
